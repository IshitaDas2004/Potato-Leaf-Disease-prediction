<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" type="image/png" href="image.png">
<title>PotatoScan — Sign In</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root {
    --white: #ffffff;
    --cream: #faf8f4;
    --cream2: #f0f7ee;
    --moss: #3a7d32;
    --moss-dark: #2e6626;
    --leaf: #5a9e4e;
    --leaf-pale: #e8f4e4;
    --leaf-mist: #f0f9ed;
    --text-dark: #1a2e16;
    --text-mid: #3a5233;
    --text-soft: #6a8265;
    --border: rgba(74,140,63,0.22);
    --error: #c0392b;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    min-height: 100vh;
    background: var(--cream);
    font-family: 'DM Sans', sans-serif;
    display: flex;
    align-items: stretch;
    overflow: hidden;
    cursor: none;
  }

  .cursor {
    width: 10px; height: 10px;
    background: var(--moss);
    border-radius: 50%;
    position: fixed;
    pointer-events: none;
    z-index: 9999;
    transform: translate(-50%,-50%);
    transition: transform 0.15s ease;
  }
  .cursor-ring {
    width: 34px; height: 34px;
    border: 1.5px solid var(--moss);
    border-radius: 50%;
    position: fixed;
    pointer-events: none;
    z-index: 9998;
    opacity: 0.4;
    transform: translate(-50%,-50%);
    transition: all 0.32s cubic-bezier(0.23,1,0.32,1);
  }
  .cursor.big  { transform: translate(-50%,-50%) scale(2.4); }
  .cursor-ring.big { opacity: 0.18; transform: translate(-50%,-50%) scale(1.5); }

  .left-panel {
    width: 48%;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background: linear-gradient(145deg, #2e6626 0%, #3a7d32 50%, #4a9e40 100%);
    padding: 60px 56px;
    flex-shrink: 0;
  }

  .ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.08);
    top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    animation: rotateSlow linear infinite;
  }
  .ring:nth-child(1) { width: 320px; height: 320px; animation-duration: 30s; }
  .ring:nth-child(2) { width: 520px; height: 520px; animation-duration: 48s; animation-direction: reverse; }
  .ring:nth-child(3) { width: 700px; height: 700px; animation-duration: 66s; border-style: dashed; }
  @keyframes rotateSlow { to { transform: translate(-50%,-50%) rotate(360deg); } }

  .hero-leaf {
    position: absolute;
    opacity: 0.12;
    right: -60px;
    top: 50%;
    transform: translateY(-50%);
    animation: sway 8s ease-in-out infinite;
  }
  @keyframes sway {
    0%,100% { transform: translateY(-50%) rotate(-4deg); }
    50%      { transform: translateY(-52%) rotate(4deg); }
  }

  .mini-leaf {
    position: absolute;
    pointer-events: none;
    opacity: 0;
    animation: riseLeaf linear infinite;
  }
  @keyframes riseLeaf {
    0%   { opacity:0; transform: translateY(80px) rotate(0deg) scale(0.7); }
    12%  { opacity:0.22; }
    88%  { opacity:0.14; }
    100% { opacity:0; transform: translateY(-280px) rotate(200deg) scale(1); }
  }

  .panel-inner {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 360px;
  }

  .panel-logo {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 48px;
    text-decoration: none;
  }
  .logo-icon {
    width: 44px; height: 44px;
    background: rgba(255,255,255,0.15);
    border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px;
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.2);
    transition: transform 0.3s ease;
  }
  .panel-logo:hover .logo-icon { transform: rotate(-8deg) scale(1.1); }
  .logo-text {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    letter-spacing: 0.1em;
    color: #ffffff;
  }

  .panel-headline {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(52px, 5vw, 78px);
    line-height: 0.92;
    letter-spacing: 0.02em;
    color: #ffffff;
    margin-bottom: 20px;
  }
  .panel-headline .muted {
    color: rgba(255,255,255,0.45);
    display: block;
    font-size: 0.6em;
    letter-spacing: 0.1em;
  }

  .panel-desc {
    font-size: 14px;
    line-height: 1.8;
    color: rgba(255,255,255,0.65);
    font-weight: 300;
    margin-bottom: 44px;
  }

  .stats-row {
    display: flex;
    justify-content: center;
    gap: 32px;
  }
  .stat {
    text-align: center;
    padding: 16px 20px;
    background: rgba(255,255,255,0.08);
    border-radius: 14px;
    border: 1px solid rgba(255,255,255,0.12);
    backdrop-filter: blur(6px);
    transition: transform 0.3s ease;
  }
  .stat:hover { transform: translateY(-4px); }
  .stat-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 30px;
    color: #ffffff;
    letter-spacing: 0.04em;
    line-height: 1;
  }
  .stat-lbl {
    font-size: 10px;
    font-family: 'Space Mono', monospace;
    color: rgba(255,255,255,0.5);
    letter-spacing: 0.1em;
    margin-top: 4px;
    text-transform: uppercase;
  }

  .right-panel {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--white);
    padding: 60px 64px;
    position: relative;
    overflow: hidden;
  }

  .right-panel::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 90% 10%, rgba(90,158,78,0.06) 0%, transparent 50%),
      radial-gradient(circle at 10% 90%, rgba(168,217,108,0.06) 0%, transparent 50%);
    pointer-events: none;
  }

  .form-box {
    width: 100%;
    max-width: 400px;
    position: relative;
    z-index: 1;
    animation: slideIn 0.75s cubic-bezier(0.23,1,0.32,1) both;
  }
  @keyframes slideIn {
    from { opacity:0; transform: translateY(32px); }
    to   { opacity:1; transform: translateY(0); }
  }

  .form-eyebrow {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.16em;
    color: var(--moss);
    text-transform: uppercase;
    margin-bottom: 12px;
    animation: slideIn 0.65s ease 0.1s both;
  }
  .eyebrow-line {
    width: 28px; height: 1.5px;
    background: var(--moss);
    border-radius: 1px;
  }

  .form-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(46px, 4.5vw, 64px);
    line-height: 0.93;
    color: var(--text-dark);
    letter-spacing: 0.02em;
    margin-bottom: 8px;
    animation: slideIn 0.65s ease 0.15s both;
  }
  .form-title .green { color: var(--moss); }

  .form-sub {
    font-size: 14px;
    color: var(--text-soft);
    font-weight: 300;
    margin-bottom: 40px;
    line-height: 1.6;
    animation: slideIn 0.65s ease 0.2s both;
  }
  .form-sub a {
    color: var(--moss);
    font-weight: 500;
    text-decoration: none;
    border-bottom: 1.5px solid rgba(58,125,50,0.3);
    transition: border-color 0.2s;
  }
  .form-sub a:hover { border-color: var(--moss); }

  .field-group {
    margin-bottom: 20px;
    animation: slideIn 0.6s ease both;
  }

  .field-label {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--text-mid);
    margin-bottom: 7px;
  }

  .input-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .i-icon {
    position: absolute;
    left: 15px;
    color: var(--text-soft);
    pointer-events: none;
    transition: color 0.25s;
    display: flex;
    align-items: center;
  }

  input[type="email"],
  input[type="password"],
  input[type="text"] {
    width: 100%;
    padding: 14px 14px 14px 44px;
    border: 1.5px solid var(--border);
    border-radius: 13px;
    background: var(--leaf-mist);
    font-family: 'DM Sans', sans-serif;
    font-size: 14.5px;
    color: var(--text-dark);
    outline: none;
    transition: all 0.28s cubic-bezier(0.23,1,0.32,1);
    appearance: none;
    cursor: text;
  }
  input::placeholder { color: var(--text-soft); opacity: 0.65; }
  input:focus {
    border-color: var(--moss);
    background: var(--white);
    box-shadow: 0 0 0 3.5px rgba(58,125,50,0.1);
  }
  .input-wrap:focus-within .i-icon { color: var(--moss); }

  .field-group.valid input { border-color: rgba(58,125,50,0.55); background: #f3fbf1; }
  .field-group.error input { border-color: rgba(192,57,43,0.5); background: #fff8f7;
    animation: shake 0.4s cubic-bezier(0.36,0.07,0.19,0.97); }
  @keyframes shake {
    0%,100% { transform:translateX(0); }
    20%     { transform:translateX(-6px); }
    40%     { transform:translateX(6px); }
    60%     { transform:translateX(-4px); }
    80%     { transform:translateX(4px); }
  }

  .tick {
    position: absolute; right: 14px;
    color: var(--moss);
    opacity: 0;
    transition: opacity 0.25s;
    pointer-events: none;
  }
  .field-group.valid .tick { opacity: 1; }

  .err-msg {
    font-size: 11px;
    color: var(--error);
    font-family: 'Space Mono', monospace;
    margin-top: 5px;
    opacity: 0;
    transform: translateY(-5px);
    transition: all 0.25s ease;
    min-height: 15px;
  }
  .field-group.error .err-msg { opacity:1; transform:translateY(0); }

  .pw-toggle-btn {
    position: absolute; right: 14px;
    background: none; border: none;
    cursor: pointer;
    color: var(--text-soft);
    padding: 0;
    display: flex; align-items: center;
    transition: color 0.2s;
    z-index: 1;
  }
  .pw-toggle-btn:hover { color: var(--moss); }

  .forgot-link {
    display: block;
    text-align: right;
    font-size: 12px;
    color: var(--moss);
    font-weight: 500;
    font-family: 'Space Mono', monospace;
    letter-spacing: 0.04em;
    text-decoration: none;
    margin-top: 8px;
    transition: opacity 0.2s;
  }
  .forgot-link:hover { opacity: 0.7; }

  .remember-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 24px 0 22px;
    animation: slideIn 0.6s ease 0.35s both;
  }
  #rememberMe { display: none; }
  .check-box {
    width: 19px; height: 19px;
    border: 1.5px solid var(--border);
    border-radius: 6px;
    background: var(--leaf-mist);
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.22s ease;
    flex-shrink: 0;
  }
  #rememberMe:checked + .check-box {
    background: var(--moss);
    border-color: var(--moss);
  }
  #rememberMe:checked + .check-box::after {
    content: '';
    width: 10px; height: 6px;
    border-left: 2px solid #fff;
    border-bottom: 2px solid #fff;
    transform: rotate(-45deg) translateY(-1px);
    display: block;
  }
  .remember-label {
    font-size: 13px;
    color: var(--text-soft);
    cursor: pointer;
    user-select: none;
  }

  .signin-btn {
    width: 100%;
    padding: 16px;
    background: var(--moss);
    color: #ffffff;
    border: none;
    border-radius: 13px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 0.09em;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.23,1,0.32,1);
    animation: slideIn 0.6s ease 0.4s both;
  }
  .signin-btn::before {
    content:'';
    position:absolute; inset:0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
    transform: translateX(-100%);
    transition: transform 0.55s ease;
  }
  .signin-btn:hover::before { transform: translateX(100%); }
  .signin-btn:hover {
    background: var(--moss-dark);
    transform: translateY(-2px);
    box-shadow: 0 14px 30px rgba(58,125,50,0.36);
  }
  .signin-btn:active { transform: translateY(0); }
  .signin-btn:disabled {
    background: #b5cdb0;
    cursor: not-allowed;
    transform: none; box-shadow: none;
  }

  .btn-inner {
    display: flex; align-items: center; justify-content: center; gap: 10px;
  }
  .btn-spinner {
    width: 18px; height: 18px;
    border: 2.5px solid rgba(255,255,255,0.35);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    display: none;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .or-divider {
    display: flex;
    align-items: center;
    gap: 14px;
    margin: 28px 0 22px;
    animation: slideIn 0.6s ease 0.45s both;
  }
  .or-line { flex:1; height:1px; background: var(--border); }
  .or-text {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: var(--text-soft);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .social-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    animation: slideIn 0.6s ease 0.5s both;
  }
  .social-btn {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    padding: 11px 16px;
    border: 1.5px solid var(--border);
    border-radius: 11px;
    background: var(--leaf-mist);
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: var(--text-dark);
    cursor: pointer;
    transition: all 0.25s ease;
    text-decoration: none;
  }
  .social-btn:hover {
    border-color: var(--moss);
    background: var(--white);
    box-shadow: 0 2px 12px rgba(74,140,63,0.1);
    transform: translateY(-1px);
  }

  .error-banner {
    display: none;
    align-items: center;
    gap: 10px;
    padding: 13px 16px;
    background: rgba(192,57,43,0.07);
    border: 1px solid rgba(192,57,43,0.25);
    border-radius: 11px;
    margin-bottom: 20px;
    font-size: 13px;
    color: var(--error);
    animation: slideIn 0.4s ease both;
  }
  .error-banner.show { display: flex; }

  .success-overlay {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    animation: slideIn 0.7s ease both;
  }
  .success-overlay.show { display: flex; }
  .success-circle {
    width: 76px; height: 76px;
    background: linear-gradient(135deg, var(--leaf), var(--moss));
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 24px;
    box-shadow: 0 10px 28px rgba(58,125,50,0.3);
    animation: popBounce 0.65s cubic-bezier(0.34,1.56,0.64,1) 0.1s both;
  }
  @keyframes popBounce {
    from { transform: scale(0); opacity:0; }
    to   { transform: scale(1); opacity:1; }
  }
  .success-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 54px;
    color: var(--text-dark);
    letter-spacing: 0.03em;
    line-height: 1;
    margin-bottom: 10px;
  }
  .success-title span { color: var(--moss); }
  .success-desc {
    font-size: 14px;
    color: var(--text-soft);
    font-weight: 300;
    line-height: 1.7;
    margin-bottom: 30px;
  }
  .goto-btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 14px 32px;
    background: var(--moss);
    color: #fff;
    border: none; border-radius: 12px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    letter-spacing: 0.08em;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .goto-btn:hover { background: var(--moss-dark); transform: translateY(-2px); box-shadow: 0 10px 22px rgba(58,125,50,0.3); }

  @media (max-width: 820px) {
    body { flex-direction: column; overflow-y: auto; }
    .left-panel { width: 100%; min-height: auto; padding: 36px 32px 32px; }
    .panel-headline, .panel-desc, .stats-row { display: none; }
    .panel-logo { margin-bottom: 0; }
    .right-panel { padding: 48px 28px; }
  }
</style>
</head>
<body>

<div class="cursor" id="cur"></div>
<div class="cursor-ring" id="curRing"></div>

<div class="left-panel">
  <div class="ring"></div>
  <div class="ring"></div>
  <div class="ring"></div>

  <div class="hero-leaf">
    <svg width="320" height="420" viewBox="0 0 320 420" fill="none">
      <path d="M160 10C90 70 30 160 60 260C90 360 220 400 270 310C320 220 280 80 160 10Z" fill="white"/>
      <path d="M160 10 L160 400" stroke="white" stroke-width="2" opacity="0.4"/>
      <path d="M160 80 Q200 140 240 200" stroke="white" stroke-width="1.5" opacity="0.3"/>
      <path d="M160 120 Q120 170 90 230" stroke="white" stroke-width="1.5" opacity="0.3"/>
    </svg>
  </div>

  <div id="miniLeaves"></div>

  <div class="panel-inner">
    <a href="#" class="panel-logo">
      <div class="logo-icon">🌿</div>
      <span class="logo-text">PotatoScan</span>
    </a>

    <div class="panel-headline">
      Welcome<br>
      <span class="muted">Back to</span>
      Scanner
    </div>

    <p class="panel-desc">
      Sign in to access your dashboard, view past diagnoses, and protect your potato crops with AI precision.
    </p>

    <div class="stats-row">
      <div class="stat">
        <div class="stat-num">97.4%</div>
        <div class="stat-lbl">Accuracy</div>
      </div>
      <div class="stat">
        <div class="stat-num">&lt;2s</div>
        <div class="stat-lbl">Analysis</div>
      </div>
      <div class="stat">
        <div class="stat-num">50K+</div>
        <div class="stat-lbl">Scans Done</div>
      </div>
    </div>
  </div>
</div>

<div class="right-panel">
  <div class="form-box">

    <div class="success-overlay" id="successScreen">
      <div class="success-circle">
        <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>
      <div class="success-title">You're<br><span>In!</span></div>
      <p class="success-desc">Welcome back. Redirecting you to your dashboard where your leaf scans are waiting.</p>
      <!-- FIX: Use onclick with window.location.href for reliable redirect in all environments -->
      <button class="goto-btn" onclick="window.location.href='/home'">
        Go to Dashboard
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </button>
    </div>

    <div id="loginForm">
      <div class="form-eyebrow">
        <div class="eyebrow-line"></div>
        Sign In
      </div>

      <div class="form-title">
        Hello,<br><span class="green">Again</span>
      </div>

      <p class="form-sub">
        Don't have an account? <a href="/signup">Create one free →</a>
      </p>

      <div class="error-banner" id="errBanner">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span id="bannerMsg">Invalid email or password. Please try again.</span>
      </div>

      <form id="theForm" novalidate>

        <div class="field-group" id="fg-email" style="animation-delay:0.25s">
          <div class="field-label">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            Email Address
          </div>
          <div class="input-wrap">
            <span class="i-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </span>
            <input type="email" id="emailInput" placeholder="you@example.com" autocomplete="email">
            <span class="tick">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
          </div>
          <div class="err-msg" id="emailErr">Please enter a valid email address</div>
        </div>

        <div class="field-group" id="fg-pass" style="animation-delay:0.32s">
          <div class="field-label">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            Password
          </div>
          <div class="input-wrap">
            <span class="i-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </span>
            <input type="password" id="passInput" placeholder="Enter your password" autocomplete="current-password">
            <button type="button" class="pw-toggle-btn" id="eyeBtn">
              <svg id="eyeSvg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          </div>
          <a href="#" class="forgot-link">Forgot password?</a>
          <div class="err-msg" id="passErr">Password must be at least 6 characters</div>
        </div>

        <div class="remember-row">
          <input type="checkbox" id="rememberMe">
          <label for="rememberMe" class="check-box"></label>
          <label for="rememberMe" class="remember-label">Remember me for 30 days</label>
        </div>

        <button type="submit" class="signin-btn" id="signInBtn">
          <div class="btn-inner">
            <div class="btn-spinner" id="btnSpinner"></div>
            <span id="btnText">Sign In →</span>
          </div>
        </button>

      </form>

      <div class="or-divider">
        <div class="or-line"></div>
        <span class="or-text">or continue with</span>
        <div class="or-line"></div>
      </div>

      <div class="social-row">
        <a href="/auth/google" class="social-btn">
          <svg width="18" height="18" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          Google
        </a>
        <!-- <a href="#" class="social-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.155-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.161 22 16.416 22 12c0-5.523-4.477-10-10-10z"/></svg>
          GitHub
        </a> -->
      </div>
    </div>

  </div>
</div>

<script>
  // ── Cursor ──
  const cur = document.getElementById('cur');
  const curRing = document.getElementById('curRing');
  let mx=0,my=0,rx=0,ry=0;
  document.addEventListener('mousemove', e => {
    mx=e.clientX; my=e.clientY;
    cur.style.left=mx+'px'; cur.style.top=my+'px';
  });
  (function loop(){
    rx+=(mx-rx)*0.13; ry+=(my-ry)*0.13;
    curRing.style.left=rx+'px'; curRing.style.top=ry+'px';
    requestAnimationFrame(loop);
  })();
  document.querySelectorAll('input,button,a,label').forEach(el=>{
    el.addEventListener('mouseenter',()=>{ cur.classList.add('big'); curRing.classList.add('big'); });
    el.addEventListener('mouseleave',()=>{ cur.classList.remove('big'); curRing.classList.remove('big'); });
  });

  // ── Mini leaves ──
  const ml = document.getElementById('miniLeaves');
  for(let i=0;i<12;i++){
    const l=document.createElement('div');
    l.className='mini-leaf';
    l.style.cssText=`left:${8+Math.random()*84}%; bottom:0; animation-duration:${9+Math.random()*13}s; animation-delay:${Math.random()*16}s;`;
    const s=12+Math.random()*14;
    l.innerHTML=`<svg width="${s}" height="${s*1.3}" viewBox="0 0 24 30" fill="none"><path d="M12 2C8 8 4 15 6 21C8 27 16 28 19 22C22 16 18 6 12 2Z" fill="white"/></svg>`;
    ml.appendChild(l);
  }

  // ── Password toggle ──
  document.getElementById('eyeBtn').addEventListener('click',()=>{
    const p=document.getElementById('passInput');
    const show=p.type==='password';
    p.type=show?'text':'password';
    document.getElementById('eyeSvg').innerHTML=show
      ?'<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23" stroke-linecap="round"/>'
      :'<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
  });

  // ── Validation ──
  const emailRx=/^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  function setField(id,ok,show){
    const fg=document.getElementById('fg-'+id);
    fg.classList.remove('valid','error');
    if(!show) return;
    fg.classList.add(ok?'valid':'error');
  }

  document.getElementById('emailInput').addEventListener('input',function(){
    setField('email', emailRx.test(this.value), this.value.length>0);
  });
  document.getElementById('passInput').addEventListener('input',function(){
    setField('pass', this.value.length>=6, this.value.length>0);
  });

  // ── Submit ──
  document.getElementById('theForm').addEventListener('submit', async e => {
  e.preventDefault();
  const email = document.getElementById('emailInput').value;
  const pass  = document.getElementById('passInput').value;
  let ok = true;

  if (!emailRx.test(email)) { setField('email', false, true); ok = false; }
  else setField('email', true, true);

  if (pass.length < 6) { setField('pass', false, true); ok = false; }
  else setField('pass', true, true);

  if (!ok) {
    document.getElementById('errBanner').classList.add('show');
    document.getElementById('bannerMsg').textContent = 'Please fix the errors above.';
    return;
  }
  document.getElementById('errBanner').classList.remove('show');

    // Loading state
  const btn     = document.getElementById('signInBtn');
  const spinner = document.getElementById('btnSpinner');
  const txt     = document.getElementById('btnText');
  btn.disabled          = true;
  spinner.style.display = 'block';
  txt.textContent       = 'Signing In…';

  try {
    const res = await fetch('/', {
      method:  'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body:    `email=${encodeURIComponent(email)}&password=${encodeURIComponent(pass)}`,
      redirect: 'follow',   // follow the server's redirect to /home
    });

    if (res.ok && res.url.includes('/home')) {
      // Server redirected us to /home — show success then navigate
      document.getElementById('loginForm').style.display = 'none';
      document.getElementById('successScreen').classList.add('show');
      setTimeout(() => { window.location.href = '/home'; }, 1500);
    } else {
      // Server returned an error
      const msg = await res.text();
      document.getElementById('errBanner').classList.add('show');
      document.getElementById('bannerMsg').textContent = msg || 'Invalid email or password.';
      btn.disabled          = false;
      spinner.style.display = 'none';
      txt.textContent       = 'Sign In →';
    }
  } catch (err) {
    document.getElementById('errBanner').classList.add('show');
    document.getElementById('bannerMsg').textContent = 'Network error. Please try again.';
    btn.disabled          = false;
    spinner.style.display = 'none';
    txt.textContent       = 'Sign In →';
  }
});
</script>
</body>
</html>